RewriteEngine On

# Redireciona URLs antigas para novas URLs
RewriteCond %{THE_REQUEST} \s/HTML/login\.html [NC]
RewriteRule ^HTML/login\.html$ /login [R=301,L]

RewriteCond %{THE_REQUEST} \s/HTML/cadastro\.html [NC]
RewriteRule ^HTML/cadastro\.html$ /cadastro [R=301,L]

RewriteCond %{THE_REQUEST} \s/HTML/home\.html [NC]
RewriteRule ^HTML/home\.html$ /home [R=301,L]

RewriteCond %{THE_REQUEST} \s/HTML/adm\.html [NC]
RewriteRule ^HTML/adm\.html$ /adm [R=301,L]

# Mapeia URLs amigáveis para os arquivos reais
RewriteRule ^login$ HTML/login.html [L]
RewriteRule ^cadastro$ HTML/cadastro.html [L]
RewriteRule ^home$ HTML/home.html [L]
RewriteRule ^adm$ HTML/adm.html [L]

# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit